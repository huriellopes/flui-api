# Copie para .env e ajuste os valores.

# Conexão com o Postgres (container dedicado na rede interna do compose).
DATABASE_URL="postgresql://notifywater:CHANGE_ME@flui-db:5432/notifywater?schema=public"

# Segredo do JWT — gere um valor forte (ex: openssl rand -hex 32).
JWT_SECRET="CHANGE_ME"
JWT_EXPIRES_IN="7d"

# Porta que a API expõe dentro do container.
PORT=3000

# Credenciais usadas pelo container do Postgres (docker-compose).
POSTGRES_USER=notifywater
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=notifywater

# Documentação (/docs). Privada por Basic Auth enquanto DOCS_PUBLIC != true.
DOCS_USER=admin
DOCS_PASSWORD=CHANGE_ME
DOCS_PUBLIC=false

# URL pública da API — usada para montar o link das imagens dos posts.
PUBLIC_URL=https://flui-api.cantinbr.com.br

# --- Monitoramento via Telegram (bot @fluiapp_bot) ---------------------------
# Token do bot (BotFather). Sem ele, o monitoramento fica desativado (no-op).
TELEGRAM_BOT_TOKEN=
# ID do chat/grupo de destino. Grupo "Suporte em Geral": -1003346127818
TELEGRAM_CHAT_ID=-1003346127818
# Nome exibido no cabeçalho das mensagens.
TELEGRAM_APP_NAME=FLUI API
# Encaminhar warn/error/fatal do logger para o Telegram (true por padrão).
TELEGRAM_FORWARD_LOGS=true
# IDs dos tópicos (threads) do grupo de fórum. Se vazios, vão para o "Geral".
# Roteamento: erros/warnings/incidentes/crashes -> ALERTS; avisos de sistema
# (API online/encerrando) e 404 -> Geral. Tópico "Alertas FluiApp" = 1122.
TELEGRAM_THREAD_ALERTS=1122
TELEGRAM_THREAD_SUPPORT=
TELEGRAM_THREAD_DEBUG=
